---
const eyebrow = "Archive Index / 01";
const headline = "classic design systems: A curated collection of timeless principles.";
const lede =
	"Compiler is a technical repository dedicated to the preservation of visual languages that shaped the modern world. From the rigorous grids of the Swiss to the functional geometry of the Bauhaus.";
---

<section class="border-b border-black px-margin py-stack-xl">
	<div class="max-w-screen-xl">
		<p class="mb-stack-sm font-label-caps text-label-caps uppercase text-secondary">
			{eyebrow}
		</p>
		<h1 class="mb-stack-md max-w-4xl font-headline-xl text-headline-xl">
			{headline}
		</h1>
		<div class="grid grid-cols-12 gap-gutter">
			<p class="col-span-12 font-body-lg text-body-lg text-on-surface-variant md:col-span-6">
				{lede}
			</p>
		</div>
	</div>
</section>
