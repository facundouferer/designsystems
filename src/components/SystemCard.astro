---
interface Props {
	index: string;
	category: string;
	icon: string;
	title: string;
	description: string;
	href?: string;
	target?: string;
	rel?: string;
	image?: string;
	imageAlt?: string;
	accent?: string;
	accentInk?: string;
	motif?: string;
}

const {
	index,
	category,
	icon,
	title,
	description,
	href = "#",
	target,
	rel,
	image,
	imageAlt,
	accent,
	accentInk = "#ffffff",
	motif,
} = Astro.props;
---

<article
	class="group flex h-[600px] flex-col justify-between border-b border-r border-black bg-surface-container-lowest p-8 transition-none hover:bg-primary hover:text-on-primary"
>
	<div>
		<div class="mb-stack-lg flex items-start justify-between">
			<span class="font-mono-data text-mono-data opacity-50">
				{index} / {category}
			</span>
			<span class="material-symbols-outlined">{icon}</span>
		</div>
		<h3 class="mb-stack-sm font-headline-md text-headline-md uppercase">{title}</h3>
		<p class="mb-stack-md font-body-md text-body-md opacity-70">{description}</p>
	</div>

	{
		image ? (
			<div class="relative mb-stack-md aspect-square w-full overflow-hidden border border-black bg-surface-container-high">
				<img
					class="h-full w-full object-cover grayscale transition-none group-hover:grayscale-0"
					src={image}
					alt={imageAlt ?? ""}
					loading="lazy"
				/>
			</div>
		) : (
			<div
				class="relative mb-stack-md flex aspect-square w-full items-end justify-between overflow-hidden border border-black p-6"
				style={{ backgroundColor: accent, color: accentInk }}
			>
				<span class="font-headline-xl text-headline-xl leading-none">
					{motif ?? index}
				</span>
				<span class="material-symbols-outlined" style={{ fontSize: "72px" }}>
					{icon}
				</span>
			</div>
		)
	}

	<a
		href={href}
		target={target}
		rel={rel}
		class="inline-flex w-fit items-center gap-2 border-b border-current pb-1 font-label-caps text-label-caps"
	>
		EXPLORE
		<span class="material-symbols-outlined text-sm">
			{target === "_blank" ? "open_in_new" : "arrow_forward"}
		</span>
	</a>
</article>
