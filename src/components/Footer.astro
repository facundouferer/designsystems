---
const links = [
	{ label: "DOCUMENTATION", href: "https://github.com/facundouferer/designsystems", emphasis: true },
	{ label: "GITHUB", href: "https://github.com/facundouferer/" },
	{ label: "CONTACT", href: "https://facundouferer.ar/#contact" },
];
---

<footer
	class="mt-stack-xl flex w-full flex-row items-center justify-between border-t border-black bg-surface-container-lowest px-margin py-8 font-headline-md text-[10px] uppercase tracking-tight text-on-background"
>
	<div class="flex flex-col gap-2">
		<div class="font-bold">CDS ARCHIVE v1.0.4</div>
		<div class="text-outline">DESIGN AND DEVELOPED BY FACUNDO UFERER</div>
	</div>
	<div class="flex gap-12">
		{
			links.map((link) => (
				<a
					href={link.href}
					class:list={[
						"text-outline transition-none hover:text-on-background",
						link.emphasis && "font-bold underline",
					]}
				>
					{link.label}
				</a>
			))
		}
	</div>
</footer>
