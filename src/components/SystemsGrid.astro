---
import SystemCard from "./SystemCard.astro";

const base = "/designsystems";

const systems = [
	{
		index: "01",
		category: "GEOMETRY",
		icon: "architecture",
		title: "Blueprint: Technical Drawing",
		description:
			"Monospaced grids, cyanotype palette, and engineering rigor. A reference language for schematics and data.",
		href: `${base}/systems-raw/blueprint.html`,
		target: "_blank",
		rel: "noopener",
		accent: "#0A1628",
		accentInk: "#DDEEFF",
		motif: "BP",
	},
	{
		index: "02",
		category: "RAW",
		icon: "bolt",
		title: "Brutalist: Unfiltered Structure",
		description:
			"Loud neons, heavy display type, and unapologetic contrast. Function screaming over polish.",
		href: `${base}/systems-raw/brutalist.html`,
		target: "_blank",
		rel: "noopener",
		accent: "#FFE500",
		accentInk: "#000000",
		motif: "BR",
	},
	{
		index: "03",
		category: "REDUCTION",
		icon: "remove",
		title: "Minimalism: Silent Interface",
		description:
			"Ample whitespace, muted greys, and one sharp accent. Every element earns its place.",
		href: `${base}/systems-raw/minimalism.html`,
		target: "_blank",
		rel: "noopener",
		accent: "#F4F4F4",
		accentInk: "#212121",
		motif: "MN",
	},
	{
		index: "04",
		category: "CLARITY",
		icon: "grid_view",
		title: "Swiss: Order & Hierarchy",
		description:
			"Editorial grids and the objective voice of the International Typographic Style. Clarity as method.",
		href: `${base}/systems-raw/swiss.html`,
		target: "_blank",
		rel: "noopener",
		accent: "#E63329",
		accentInk: "#ffffff",
		motif: "SW",
	},
	{
		index: "05",
		category: "EXCESS",
		icon: "auto_awesome",
		title: "Maximalism: Neon Baroque",
		description:
			"Neon colors, layered shadows, and bold display type. More is more, not less.",
		href: `${base}/systems-raw/maximalism.html`,
		target: "_blank",
		rel: "noopener",
		accent: "#FF006E",
		accentInk: "#ffffff",
		motif: "MX",
	},
	{
		index: "06",
		category: "ORGANIC",
		icon: "gesture",
		title: "Hand Draw: Sketchbook",
		description:
			"Hand-drawn SVG strokes, paper textures, and imperfect lines. Design that feels made by hand.",
		href: `${base}/systems-raw/handdraw.html`,
		target: "_blank",
		rel: "noopener",
		accent: "#E8C547",
		accentInk: "#1C1917",
		motif: "HD",
	},
	{
		index: "07",
		category: "VINTAGE",
		icon: "auto_fix_high",
		title: "Retro: Four Eras",
		description:
			"Neon synthwave, Americana, groovy 70s, and Win95 pixel. Four decades of visual culture as one system.",
		href: `${base}/systems-raw/retro.html`,
		target: "_blank",
		rel: "noopener",
		accent: "#FF2D78",
		accentInk: "#E8E8FF",
		motif: "RT",
	},
];
---

<section class="px-margin py-stack-xl">
	<div
		class="grid grid-cols-1 gap-0 border-l border-t border-black md:grid-cols-2 xl:grid-cols-4"
	>
		{systems.map((system) => <SystemCard {...system} />)}
	</div>
</section>
